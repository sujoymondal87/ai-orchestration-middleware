# Required
ANTHROPIC_API_KEY=
API_PORT=3000

# AI providers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEMINI_API_KEY=

# Default provider (DeepSeek is default — cheapest)
MCP_DEFAULT_MODEL=deepseek-v4-flash
MCP_DEFAULT_PROVIDER=deepseek

# Redis (get free URL from upstash.com)
REDIS_URL=redis://localhost:6379

# Ops
NODE_ENV=development
